# ── Ambiente ────────────────────────────────────────────────────────────────
# "production" ou "development"
# Em produção: ativa HSTS preload, cookies Secure, error messages genéricas
NODE_ENV=development
PORT=3001

# ── Banco de dados (MySQL) ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=donna_hub

# ── JWT ──────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cole_aqui_64_bytes_hex_gerado_com_crypto
JWT_EXPIRE=7d

# ── CORS (produção) ──────────────────────────────────────────────────────────
# Lista de domínios autorizados separados por vírgula (sem espaços)
# Em development, localhost é liberado automaticamente — esta var é ignorada
ALLOWED_ORIGINS=https://donna.vercel.app,https://www.donnaunha.com.br

# ── Fórmula de preços ────────────────────────────────────────────────────────
FORMULA_CUSTOS=22.18
FORMULA_CARTAO=6.00
